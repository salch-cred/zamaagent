# PayMate frontend env.
# Copy to .env.local and fill in. Addresses stay zero until Sepolia deploy (DEV FILE 5).

# Infura (or Alchemy) project ID — used by wagmi's Sepolia transport.
NEXT_PUBLIC_INFURA_KEY=your_infura_key_here

# Contract addresses (populated after `npx hardhat deploy --network sepolia`)
NEXT_PUBLIC_PAYROLL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_INVOICE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AIRDROP_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CHAIN_ID=11155111
